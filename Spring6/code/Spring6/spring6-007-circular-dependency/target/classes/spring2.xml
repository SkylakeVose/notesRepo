<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!--构造注入，这种循环依赖是否有问题？-->
    <!--基于构造注入的方式下产生的循环依赖也是无法解决的-->
    <bean id="hb" class="cn.piggy.spring6.bean2.Husband" scope="prototype">
        <constructor-arg index="0" value="张三"/>
        <constructor-arg index="1" ref="wb"/>
    </bean>

    <bean id="wb" class="cn.piggy.spring6.bean2.Wife" scope="singleton">
        <constructor-arg index="0" value="小花"/>
        <constructor-arg index="1" ref="hb"/>
    </bean>

</beans>