<?xml version="1.0" encoding="UTF-8" ?>
<mapper namespace="user">

    <insert id="insertUser">
        insert into t_user values(#{id}, #{name}, #{age})
    </insert>

    <select id="selectById" resultType="cn.piggy.godbatis.pojo.User">
        select * from t_user where id = #{id}
    </select>
</mapper>