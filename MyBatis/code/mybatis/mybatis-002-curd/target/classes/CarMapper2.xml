<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!--namespace先随意写一个-->
<mapper namespace="car2">

    <select id="selectAll" resultType="cn.piggy.mybatis.pojo.Car">
        select
            id,
            car_num as carNum,
            brand,
            guide_price as guidePrice,
            produce_time as produceTime,
            car_type as carType
        from
            t_car
    </select>

    <select id="selectById" resultType="cn.piggy.mybatis.pojo.Car">
        select
            id,
            car_num as carNum,
            brand,
            guide_price as guidePrice,
            produce_time as produceTime,
            car_type as carType
        from
            t_car
        where
            id = #{id}
    </select>

    <update id="updateById">
        update t_car set car_num=#{carNum}, brand=#{brand}, guide_price=#{guidePrice},
        produce_time=#{produceTime}, car_type=#{carType} where id = #{id}
    </update>

    <delete id="deleteById">
        delete from t_car where id = #{whatever}
    </delete>

    <!--insert sql：保存一个汽车信息-->
    <insert id="insertCar">
        <!--使用Map传参-->
        <!--insert into t_car(car_num,brand,guide_price,produce_time,car_type) values(#{carNum},#{brand},#{guidePrice},#{produceTime},#{carType})-->

        <!--使用POJO传参-->
        insert into t_car(id,car_num,brand,guide_price,produce_time,car_type)
        values(null, #{carNum},#{brand},#{guidePrice},#{produceTime},#{carType})
    </insert>
</mapper>